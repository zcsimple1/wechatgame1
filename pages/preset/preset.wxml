<!--pages/preset/preset.wxml-->
<view class="container">
  <view class="header">
    <view class="back-btn" bindtap="goBack">← 返回</view>
    <view class="title">⭐ 热门预设</view>
  </view>

  <view class="content">
    <view class="category-tabs">
      <view
        class="tab {{currentCategory === item.id ? 'active' : ''}}"
        wx:for="{{categories}}"
        wx:key="id"
        bindtap="switchCategory"
        data-id="{{item.id}}"
      >
        {{item.name}}
      </view>
    </view>

    <scroll-view class="preset-list" scroll-y>
      <view class="preset-card" wx:for="{{filteredPresets}}" wx:key="id" bindtap="selectPreset" data-id="{{item.id}}">
        <view class="preset-header">
          <view class="preset-icon">{{item.icon}}</view>
          <view class="preset-name">{{item.name}}</view>
          <view class="preset-arrow">→</view>
        </view>
        <view class="preset-tags">
          <view class="tag" wx:for="{{item.options.slice(0, 4)}}" wx:for-item="opt" wx:key="*this">{{opt}}</view>
          <view class="tag more" wx:if="{{item.options.length > 4}}">+{{item.options.length - 4}}</view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 抽签结果弹窗 -->
  <view class="modal-mask" wx:if="{{showResult}}" bindtap="closeResult">
    <view class="modal-content" catchtap>
      <view class="result-icon">🎉</view>
      <view class="result-title">{{currentPreset.name}}</view>
      <view class="result-value">{{result}}</view>
      <view class="result-actions">
        <button class="retry-btn" bindtap="retryDraw">再来一次</button>
        <button class="confirm-btn" bindtap="closeResult">确定</button>
      </view>
    </view>
  </view>
</view>
