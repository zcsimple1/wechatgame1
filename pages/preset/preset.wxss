/* pages/preset/preset.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx;
  box-sizing: border-box;
}

.header {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.back-btn {
  color: #fff;
  font-size: 32rpx;
  padding: 10rpx 0;
}

.title {
  flex: 1;
  text-align: center;
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
}

.content {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.category-tabs {
  display: flex;
  gap: 15rpx;
  margin-bottom: 30rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.tab {
  padding: 15rpx 30rpx;
  background: #f0f0f0;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  flex-shrink: 0;
  transition: all 0.3s ease;
}

.tab.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-weight: bold;
}

.preset-list {
  max-height: 1200rpx;
}

.preset-card {
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 25rpx;
  margin-bottom: 20rpx;
  transition: all 0.3s ease;
}

.preset-card:active {
  transform: scale(0.98);
}

.preset-header {
  display: flex;
  align-items: center;
  margin-bottom: 15rpx;
}

.preset-icon {
  font-size: 48rpx;
  margin-right: 15rpx;
}

.preset-name {
  flex: 1;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.preset-arrow {
  font-size: 32rpx;
  color: #999;
}

.preset-tags {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.tag {
  padding: 8rpx 20rpx;
  background: #e9ecef;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #666;
}

.tag.more {
  background: #667eea;
  color: #fff;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: #fff;
  border-radius: 32rpx;
  padding: 0;
  text-align: center;
  margin: 40rpx;
  animation: modalPop 0.3s ease;
  overflow: hidden;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
  width: 600rpx;
  position: relative;
}

.modal-mask:active {
  pointer-events: auto;
}

@keyframes modalPop {
  from {
    transform: scale(0.8);
    opacity: 0;
  }
  to {
    transform: scale(1);
    opacity: 1;
  }
}

.result-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 50rpx 40rpx 40rpx;
  position: relative;
  overflow: hidden;
}

.result-background-icon {
  position: absolute;
  top: -30rpx;
  right: -30rpx;
  font-size: 200rpx;
  opacity: 0.15;
  filter: blur(2rpx);
}

.result-title {
  position: relative;
  z-index: 1;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: bold;
}

.result-value-container {
  padding: 60rpx 50rpx 50rpx;
  background: #fff;
}

.result-icon-large {
  font-size: 160rpx;
  margin-bottom: 30rpx;
  display: block;
}

.result-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.result-value-box {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 50rpx;
  background: linear-gradient(135deg, #f6d365 0%, #fda085 100%);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(246, 211, 101, 0.4);
  position: relative;
  overflow: hidden;
  min-height: 200rpx;
}

.result-value-box::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: linear-gradient(
    45deg,
    transparent 30%,
    rgba(255, 255, 255, 0.3) 50%,
    transparent 70%
  );
  animation: shine 2s infinite;
}

@keyframes shine {
  0% {
    transform: translateX(-100%) translateY(-100%);
  }
  100% {
    transform: translateX(100%) translateY(100%);
  }
}

.result-actions {
  display: flex;
  justify-content: center;
  padding: 40rpx 50rpx 50rpx;
}

.retry-btn {
  width: 300rpx;
  height: 90rpx;
  line-height: 90rpx;
  border-radius: 45rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.retry-btn:active {
  transform: scale(0.95);
}

.close-icon-btn {
  position: absolute;
  top: 30rpx;
  right: 30rpx;
  width: 60rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.8);
  cursor: pointer;
  border-radius: 50%;
  transition: all 0.3s ease;
  z-index: 10;
}

.close-icon-btn:active {
  transform: scale(0.9);
  background: rgba(255, 255, 255, 0.2);
}
