<!--pages/wheel/wheel.wxml-->
<view class="container">
  <view class="header">
    <view class="back-btn" bindtap="goBack">← 返回</view>
    <view class="title">🎡 转盘抽签</view>
  </view>

  <view class="content">
    <view class="section">
      <view class="section-title">添加转盘选项</view>
      <view class="input-row">
        <input class="option-input" placeholder="输入选项名称" value="{{newOption}}" bindinput="onOptionInput" />
        <button class="add-btn" bindtap="addOption" size="mini">添加</button>
      </view>
      <view class="tip">点击下方转盘开始抽奖</view>
    </view>

    <view class="wheel-container {{showResult ? 'modal-open' : ''}}">
      <canvas type="2d" id="wheelCanvas" class="wheel-canvas" style="{{showResult ? 'opacity: 0; visibility: hidden;' : ''}}"></canvas>
      <view class="wheel-pointer" bindtap="spinWheel" style="{{showResult ? 'opacity: 0; visibility: hidden;' : ''}}">
        <view class="pointer-text">{{isSpinning ? '点击停止' : '开始'}}</view>
      </view>
    </view>

    <view class="options-section">
      <view class="section-title">当前选项 ({{options.length}}个)</view>
      <scroll-view class="options-list" scroll-y>
        <view class="option-item" wx:for="{{options}}" wx:key="index">
          <view class="option-dot" style="background: {{item.color}}"></view>
          <view class="option-name">{{item.name}}</view>
          <view class="delete-btn" bindtap="deleteOption" data-index="{{index}}">✕</view>
        </view>
        <view wx:if="{{options.length === 0}}" class="empty-tip">
          请添加至少2个选项
        </view>
      </scroll-view>
    </view>
  </view>

  <view class="actions">
    <button class="reset-btn" bindtap="resetWheel">重置转盘</button>
    <button class="share-btn" bindtap="shareWheel" disabled="{{options.length < 2}}">分享转盘</button>
  </view>

  <view class="qrcode-section">
    <image class="qrcode-image" src="/images/qrcode.jpg" mode="aspectFit"></image>
    <view class="qrcode-text">扫码关注公众号</view>
  </view>
</view>

<!-- 结果弹出框 - 移到container外面 -->
<view class="modal-mask" wx:if="{{showResult}}" bindtap="closeResult">
  <view class="modal-content" catchtap>
    <view class="close-icon-btn" catchtap="closeResult">✕</view>
    <view class="result-header">
      <view class="result-background-icon">🎡</view>
      <view class="result-title-light">转盘抽签</view>
    </view>
    <view class="result-value-container">
      <view class="result-icon-large">🎉</view>
      <view class="result-text">{{result}}</view>
    </view>
    <view class="result-actions">
      <button class="retry-btn" catchtap="spinWheel">🔄 再来一次</button>
    </view>
  </view>
</view>
