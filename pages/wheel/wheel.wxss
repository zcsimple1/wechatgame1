/* pages/wheel/wheel.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx;
  box-sizing: border-box;
  position: relative;
  z-index: 1;
}

.content {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  position: relative;
  z-index: 2;
}

.header {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.back-btn {
  color: #fff;
  font-size: 32rpx;
  padding: 10rpx 0;
}

.title {
  flex: 1;
  text-align: center;
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
}

.content {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 15rpx;
  border-bottom: 2rpx solid #e0e0e0;
}

.input-row {
  display: flex;
  align-items: center;
  gap: 15rpx;
  margin-bottom: 15rpx;
}

.option-input {
  flex: 1;
  height: 80rpx;
  padding: 0 20rpx;
  border: 2rpx solid #ddd;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.add-btn {
  width: 140rpx;
  height: 80rpx;
  background: #4CAF50;
  color: white;
  border-radius: 12rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.tip {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.wheel-container {
  position: relative;
  width: 450rpx;
  height: 450rpx;
  margin: 20rpx auto;
  overflow: visible;
  z-index: 1;
  transition: z-index 0s;
}

.wheel-container.modal-open {
  z-index: 0;
}

.wheel-canvas {
  width: 450rpx;
  height: 450rpx;
  border-radius: 50%;
  display: block;
  background: #f0f0f0;
  position: relative;
  z-index: 1;
  transition: opacity 0.3s ease, visibility 0.3s ease;
}

.wheel-container.modal-open .wheel-canvas {
  z-index: 0;
}

.wheel-canvas {
  width: 450rpx;
  height: 450rpx;
  border-radius: 50%;
  display: block;
  background: #f0f0f0;
  position: relative;
  z-index: 1;
}

.wheel-container.modal-open .wheel-canvas {
  z-index: 1;
}

.wheel-pointer {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 130rpx;
  height: 130rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a24 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.3);
  cursor: pointer;
  transition: transform 0.2s ease, opacity 0.3s ease, visibility 0.3s ease;
  z-index: 1;
}

.wheel-container.modal-open .wheel-pointer {
  z-index: 0;
}

.wheel-pointer:active {
  transform: translate(-50%, -50%) scale(0.95);
}

.pointer-text {
  color: white;
  font-size: 28rpx;
  font-weight: bold;
  line-height: 1;
}

.options-section {
  margin-top: 30rpx;
}

.options-list {
  max-height: 300rpx;
}

.option-item {
  display: flex;
  align-items: center;
  padding: 15rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  margin-bottom: 10rpx;
}

.option-dot {
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  margin-right: 15rpx;
}

.option-name {
  flex: 1;
  font-size: 26rpx;
  color: #333;
}

.delete-btn {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  background: #ff4757;
  color: white;
  border-radius: 50%;
  font-size: 24rpx;
}

.empty-tip {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 26rpx;
}

/* 弹出框样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100000;
  animation: fadeIn 0.2s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.modal-content {
  background: #fff;
  border-radius: 32rpx;
  padding: 0;
  text-align: center;
  margin: 40rpx;
  animation: modalPop 0.3s ease;
  overflow: hidden;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
  width: 600rpx;
  position: relative;
}

@keyframes modalPop {
  from {
    transform: scale(0.8);
    opacity: 0;
  }
  to {
    transform: scale(1);
    opacity: 1;
  }
}

.result-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 50rpx 40rpx 40rpx;
  position: relative;
  overflow: hidden;
  border-radius: 32rpx 32rpx 0 0;
}

.result-background-icon {
  position: absolute;
  top: -30rpx;
  right: -30rpx;
  font-size: 200rpx;
  opacity: 0.15;
  filter: blur(2rpx);
}

.result-title-light {
  position: relative;
  z-index: 1;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: bold;
}

.result-value-container {
  padding: 60rpx 50rpx 50rpx;
  background: #fff;
}

.result-icon-large {
  font-size: 160rpx;
  margin-bottom: 30rpx;
  display: block;
}

.result-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.result-actions {
  display: flex;
  justify-content: center;
  padding: 40rpx 50rpx 50rpx;
}

.retry-btn {
  width: 300rpx;
  height: 90rpx;
  border-radius: 45rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.retry-btn:active {
  transform: scale(0.95);
}

.close-icon-btn {
  position: absolute;
  top: 30rpx;
  right: 30rpx;
  width: 60rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.8);
  border-radius: 50%;
  transition: all 0.3s ease;
  z-index: 10;
}

.close-icon-btn:active {
  transform: scale(0.9);
  background: rgba(255, 255, 255, 0.2);
}

.actions {
  display: flex;
  gap: 20rpx;
  position: relative;
  z-index: 10;
}

.reset-btn,
.share-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.reset-btn {
  background: #fff;
  color: #666;
  border: 2rpx solid #ddd;
}

.share-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

button[disabled] {
  opacity: 0.5;
}

.qrcode-section {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-top: 30rpx;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.qrcode-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  border: 2rpx solid #e0e0e0;
}

.qrcode-text {
  font-size: 24rpx;
  color: #666;
  margin-top: 15rpx;
}
