/* pages/share/share.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx;
  box-sizing: border-box;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  font-size: 60rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 15rpx;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.wheel-section {
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 40rpx 0;
}

.draw-section {
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 40rpx 0;
}

.draw-area {
  width: 100%;
  padding: 40rpx 0;
  background: linear-gradient(135deg, #f6d365 0%, #fda085 100%);
  border-radius: 16rpx;
  text-align: center;
}

.draw-button {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border: none;
  border-radius: 50rpx;
  font-size: 36rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

.close-result-btn {
  background: rgba(255, 255, 255, 0.3);
  color: #fff;
  border-radius: 30rpx;
  margin-top: 20rpx;
}

.wheel-container {
  position: relative;
  width: 600rpx;
  height: 600rpx;
  z-index: 1;
}

.wheel-container.modal-open {
  z-index: 0;
}

.wheel-canvas {
  width: 600rpx;
  height: 600rpx;
  background: #f0f0f0;
  border-radius: 50%;
  position: relative;
  z-index: 1;
  transition: opacity 0.3s ease, visibility 0.3s ease;
}

.wheel-container.modal-open .wheel-canvas {
  z-index: 0;
}

.wheel-pointer {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 140rpx;
  height: 140rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a5a 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.5);
  border: 3rpx solid #fff;
  transition: transform 0.2s ease, opacity 0.3s ease, visibility 0.3s ease;
  z-index: 1;
}

.wheel-container.modal-open .wheel-pointer {
  z-index: 0;
}

.pointer-text {
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
  text-align: center;
  line-height: 1.2;
}

.options-preview {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.preview-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
  padding-bottom: 10rpx;
  border-bottom: 2rpx solid #e0e0e0;
}

.preview-list {
  max-height: 300rpx;
}

.preview-item {
  display: flex;
  align-items: center;
  padding: 10rpx 12rpx;
  background: #f8f9fa;
  border-radius: 8rpx;
  margin-bottom: 8rpx;
}

.preview-dot {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  border: 2rpx solid rgba(0, 0, 0, 0.1);
  flex-shrink: 0;
}

.preview-name {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.preview-weight {
  font-size: 22rpx;
  color: #666;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.actions {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
  justify-content: center;
}

.share-btn {
  width: 400rpx;
  height: 90rpx;
  border-radius: 45rpx;
  font-size: 32rpx;
  font-weight: bold;
  background: #fff;
  color: #667eea;
  border: 2rpx solid #667eea;
  display: flex;
  align-items: center;
  justify-content: center;
}

.qrcode-section {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.qrcode-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  border: 2rpx solid #e0e0e0;
}

.qrcode-text {
  font-size: 24rpx;
  color: #666;
  margin-top: 15rpx;
}

.creator {
  text-align: center;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 模态框样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100000;
  padding: 40rpx;
}

.modal-content {
  background: white;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  width: 100%;
  max-width: 500rpx;
  text-align: center;
  position: relative;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.close-icon-btn {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 50rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #999;
  cursor: pointer;
  border-radius: 50%;
  transition: background 0.2s;
}

.close-icon-btn:hover {
  background: #f0f0f0;
}

.result-header {
  margin-bottom: 40rpx;
}

.result-background-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.result-title-light {
  font-size: 28rpx;
  color: #999;
  font-weight: 500;
}

.result-value-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 50rpx;
}

.result-icon-large {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.result-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.4;
}

.result-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.retry-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 50rpx;
  height: 90rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

button[disabled] {
  opacity: 0.5;
}
