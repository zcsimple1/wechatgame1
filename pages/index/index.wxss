/* pages/index/index.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx;
  box-sizing: border-box;
}

.header {
  text-align: center;
  margin-bottom: 50rpx;
  padding-top: 40rpx;
}

.title {
  font-size: 72rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 15rpx;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.content {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.card-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.card {
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  position: relative;
  cursor: pointer;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.card:active {
  transform: scale(0.98);
}

.card-icon {
  font-size: 64rpx;
  margin-bottom: 15rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.card-desc {
  font-size: 24rpx;
  color: #666;
}

.card-arrow {
  position: absolute;
  top: 30rpx;
  right: 30rpx;
  font-size: 40rpx;
  color: #999;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 15rpx;
  border-bottom: 2rpx solid #e0e0e0;
}

.preset-list {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 15rpx;
}

.preset-item {
  text-align: center;
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  cursor: pointer;
  transition: all 0.3s ease;
  min-height: 180rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.preset-item:active {
  transform: scale(0.95);
}

.preset-icon {
  font-size: 64rpx;
  margin-bottom: 12rpx;
}

.preset-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  animation: fadeIn 0.2s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.modal-content {
  background: #fff;
  border-radius: 32rpx;
  padding: 0;
  text-align: center;
  margin: 40rpx;
  animation: modalPop 0.3s ease;
  overflow: hidden;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
  width: 600rpx;
  position: relative;
}

@keyframes modalPop {
  from {
    transform: scale(0.8);
    opacity: 0;
  }
  to {
    transform: scale(1);
    opacity: 1;
  }
}

.result-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 50rpx 40rpx 40rpx;
  position: relative;
  overflow: hidden;
  border-radius: 32rpx 32rpx 0 0;
}

.result-background-icon {
  position: absolute;
  top: -30rpx;
  right: -30rpx;
  font-size: 200rpx;
  opacity: 0.15;
  filter: blur(2rpx);
}

.result-title-light {
  position: relative;
  z-index: 1;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: bold;
}

.result-value-container {
  padding: 60rpx 50rpx 50rpx;
  background: #fff;
}

.result-icon-large {
  font-size: 160rpx;
  margin-bottom: 30rpx;
  display: block;
}

.result-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.result-actions {
  display: flex;
  justify-content: center;
  padding: 40rpx 50rpx 50rpx;
}

.retry-btn {
  width: 300rpx;
  height: 90rpx;
  line-height: 90rpx;
  border-radius: 45rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.retry-btn:active {
  transform: scale(0.95);
}

.close-icon-btn {
  position: absolute;
  top: 30rpx;
  right: 30rpx;
  width: 60rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.8);
  border-radius: 50%;
  transition: all 0.3s ease;
  z-index: 10;
}

.close-icon-btn:active {
  transform: scale(0.9);
  background: rgba(255, 255, 255, 0.2);
}
