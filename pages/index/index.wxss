/* pages/index/index.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx;
  box-sizing: border-box;
}

.title {
  text-align: center;
  font-size: 60rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 40rpx;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.content {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 15rpx;
  border-bottom: 2rpx solid #e0e0e0;
}

.input-row {
  display: flex;
  align-items: center;
  gap: 15rpx;
  margin-bottom: 15rpx;
}

.option-input {
  flex: 1;
  height: 80rpx;
  padding: 0 20rpx;
  border: 2rpx solid #ddd;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.weight-input {
  width: 160rpx;
  height: 80rpx;
  padding: 0 20rpx;
  border: 2rpx solid #ddd;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.add-btn {
  width: 140rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: #4CAF50;
  color: white;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.tip {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.options-list {
  max-height: 400rpx;
}

.option-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  margin-bottom: 15rpx;
  border-left: 4rpx solid #667eea;
}

.option-index {
  width: 50rpx;
  height: 50rpx;
  line-height: 50rpx;
  text-align: center;
  background: #667eea;
  color: white;
  border-radius: 50%;
  font-size: 24rpx;
  font-weight: bold;
  margin-right: 15rpx;
}

.option-name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.option-weight {
  font-size: 24rpx;
  color: #666;
  margin-right: 20rpx;
}

.option-probability {
  font-size: 24rpx;
  color: #4CAF50;
  font-weight: bold;
  margin-right: 20rpx;
}

.delete-btn {
  width: 50rpx;
  height: 50rpx;
  line-height: 50rpx;
  text-align: center;
  background: #ff4757;
  color: white;
  border-radius: 50%;
  font-size: 24rpx;
}

.empty-tip {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

.result-section {
  text-align: center;
  padding: 40rpx 0;
  background: linear-gradient(135deg, #f6d365 0%, #fda085 100%);
  border-radius: 16rpx;
  margin-top: 30rpx;
}

.result-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 20rpx;
}

.result-value {
  font-size: 56rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 20rpx;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.close-result-btn {
  background: rgba(255, 255, 255, 0.3);
  color: #fff;
  border-radius: 30rpx;
}

.actions {
  display: flex;
  gap: 20rpx;
}

.share-btn,
.draw-btn {
  flex: 1;
  height: 90rpx;
  line-height: 90rpx;
  border-radius: 45rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.share-btn {
  background: #fff;
  color: #667eea;
  border: 2rpx solid #667eea;
}

.draw-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.4);
}

button[disabled] {
  opacity: 0.5;
}
