<!--pages/index/index.wxml-->
<view class="container">
  <view class="header">
    <view class="title">🎲 抽个签吧</view>
    <view class="subtitle">选择你喜欢的抽签方式</view>
  </view>

  <view class="content">
    <view class="card-grid">
      <!-- 自定义抽签 -->
      <view class="card" bindtap="goToCustom">
        <view class="card-icon">🌟</view>
        <view class="card-title">自定义抽签</view>
        <view class="card-desc">自由添加选项，设置权重</view>
        <view class="card-arrow">→</view>
      </view>

      <!-- 转盘抽签 -->
      <view class="card" bindtap="goToWheel">
        <view class="card-icon">🔥</view>
        <view class="card-title">转盘抽签</view>
        <view class="card-desc">旋转转盘，刺激有趣</view>
        <view class="card-arrow">→</view>
      </view>

      <!-- 预设抽签 -->
      <view class="card" bindtap="goToPreset">
        <view class="card-icon">💎</view>
        <view class="card-title">热门预设</view>
        <view class="card-desc">精选模板，快速使用</view>
        <view class="card-arrow">→</view>
      </view>
    </view>

    <!-- 快速入口 -->
    <view class="quick-actions">
      <view class="section-title">快速开始</view>
      <scroll-view class="preset-list" scroll-x>
        <view class="preset-item" wx:for="{{quickPresets}}" wx:key="id" bindtap="quickDraw" data-id="{{item.id}}">
          <view class="preset-icon">{{item.icon}}</view>
          <view class="preset-name">{{item.name}}</view>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 抽签结果弹窗 -->
  <view class="modal-mask" wx:if="{{showResult}}" bindtap="closeResult">
    <view class="modal-content" catchtap>
      <view class="result-icon">🎉</view>
      <view class="result-title">抽签结果</view>
      <view class="result-value">{{result}}</view>
      <button class="result-btn" bindtap="closeResult">确定</button>
    </view>
  </view>
</view>
